{
    "layer": "top",
    "position": "top",
    "height": 30,
    
    "modules-left": ["hyprland/workspaces"],
    "modules-center": ["hyprland/window"],
    "modules-right": ["hyprland/language" , "network", "battery", "clock"],

    "hyprland/workspaces": {
        "format": "{icon}",
        "on-click": "activate"
    },
    "clock": {
        "format": "{:%H:%M - %A}",
        "tooltip-format": "<tt>{calendar}</tt>"
    },
    "battery": {
        "format": "{capacity}% {icon}",
        "format-icons": ["", "", "", "", ""]
    },
    "network": {
        "format-wifi": "{essid} ",
        "format-disconnected": "Disconnected ⚠"
    },

   "hyprland/language": {
        "format": "{}",
        "format-en": "EN",
        "format-ar": "AR"
    }
}
